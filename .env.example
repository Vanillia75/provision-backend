# ============================================================
#  H€CTOR backend — variables d'environnement (EXEMPLE)
#  Copier en .env (gitignoré) et remplir. NE JAMAIS commiter de vraie valeur.
# ============================================================

# ── Base de données (Railway) ──
DATABASE_URL=

# ── Authentification ──
JWT_SECRET=
GOOGLE_CLIENT_ID=

# ── IA (Anthropic) ──
ANTHROPIC_API_KEY=
# Garde-fous anti-abus IA (par jour) — facultatif, défauts dans le code
AI_CHAT_DAILY_LIMIT=
AI_AEM_DAILY_LIMIT=

# ── Stripe (abonnement Premium) ──
STRIPE_SECRET_KEY=
STRIPE_PRICE_PREMIUM=
STRIPE_WEBHOOK_SECRET=

# ── Quotas freemium MENSUELS (facultatif — défauts : 2 / 3 / 3) ──
FREE_AEM_SCAN_PER_MONTH=
FREE_CHAT_PER_MONTH=
FREE_DOC_SCAN_PER_MONTH=

# ── Email (Resend) ──
RESEND_API_KEY=
EMAIL_FROM=
FRONTEND_URL=

# ── Connexion bancaire (Powens) ──
POWENS_CLIENT_ID=
POWENS_CLIENT_SECRET=
POWENS_DOMAIN=

# ── Stockage documents (Cloudflare R2) ──
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_ENDPOINT=
R2_BUCKET=

# ── Lookup SIRET (INSEE) ──
INSEE_API_KEY=
